{
  "$schema":  "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": ["seqkit@latest", "picard-tools@latest", "perl@latest"],
  "shell": {
    "init_hook": [
      "if [ ! -d \"$PWD/.devbox/tools/FASTAptamer\" ]; then mkdir -p \"$PWD/.devbox/tools\" && git clone --depth 1 https://github.com/FASTAptamer/FASTAptamer.git \"$PWD/.devbox/tools/FASTAptamer\" && chmod +x \"$PWD/.devbox/tools/FASTAptamer\"/fastaptamer_*; fi",
      "export PATH=\"$PWD/.devbox/tools/FASTAptamer:$PATH\""
    ],
    "scripts": {
      "fastaptamer_count":   "perl .devbox/tools/FASTAptamer/fastaptamer_count \"$@\"",
      "fastaptamer_cluster": "perl .devbox/tools/FASTAptamer/fastaptamer_cluster \"$@\"",
      "fastaptamer_compare": "perl .devbox/tools/FASTAptamer/fastaptamer_compare \"$@\"",
      "fastaptamer_enrich":  "perl .devbox/tools/FASTAptamer/fastaptamer_enrich \"$@\"",
      "fastaptamer_search":  "perl .devbox/tools/FASTAptamer/fastaptamer_search \"$@\""
    }
  }
}
